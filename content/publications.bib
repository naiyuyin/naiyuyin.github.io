@inproceedings{yin2024aaai,
  selected={true},
  title = {Effective Causal Discovery under Identifiable Heteroscedastic Noise Model},
  booktitle = {Proceedings of the AAAI Conference on Artificial Intelligence (AAAI)},
  author = {Naiyu Yin and Tian Gao and Yue Yu and Qiang Ji},
  year = {2024},
  abstract = {We investigate causal discovery under heteroscedastic noise in structural equation models (SEMs). We introduce relaxed and implementable sufficient conditions proving identifiability for a general class of SEMs. We propose a novel causal discovery formulation and a two-phase iterative algorithm to handle varying noise variance across variables and observations.},
  description = {Novel causal discovery method handling heteroscedastic noise with proven identifiability conditions.},
  keywords = {Causal Discovery, Heteroscedastic Noise, Structural Equation Models, Identifiability}
}

